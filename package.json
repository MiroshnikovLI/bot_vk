{
  "name": "bot-vk",
  "version": "1.0.0",
  "description": "Бот для автоматизации работы менеджеров пунктов выдачи Wildberries",
  "main": "src/bot/index.js",
  "author": "MiroshnikovLI",
  "license": "MIT",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "start": "pm2 start ecosystem.config.js",
    "stop": "pm2 stop all",
    "restart": "pm2 restart all",
    "delete": "pm2 delete all",
    "logs": "pm2 logs",
    "status": "pm2 status",
    "dev:bot": "nodemon src/bot/index.js",
    "dev:server": "nodemon src/server/index.js",
    "dev:scheduler": "nodemon src/sheduler/index.js",
    "dev:all": "concurrently \"npm run dev:bot\" \"npm run dev:server\" \"npm run dev:scheduler\"",
    "build:panel": "cd panel && npm run build",
    "install:all": "npm install && cd panel && npm install",
    "db:init": "node src/database/init.js",
    "db:migrate": "node src/database/migrate.js",
    "lint": "eslint src/",
    "format": "pattier --write \"**/*.{js,jsx,json,css}\""
  },
  "dependencies": {
    "vk-io": "^4.9.2",
    "pg": "^8.11.3",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "axios": "^1.6.2",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "express-validator": "^7.0.1",
    "helmet": "^7.0.1",
    "morgan": "^1.10.0",
    "compression": "^1.7.4"
  },
  "devDependencies": {
    "nodemon": "^3.0.2",
    "concurrently": "^8.2.2",
    "pm2": "^5.3.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "jest": "^29.7.0"
  },
  "jest": {
    "testEvniroment": "node",
    "coveragePathIgnorePatterns" : [
      "/node_modules/"
    ]
  }
}